# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15005550006
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Tavily
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxx

# Ollama / Qwen
# Bare metal: http://localhost:11434
# Docker:     overridden in docker-compose.yml → http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Whisper STT microservice
# Bare metal: http://localhost:8080  (run whisper container separately)
# Docker:     overridden in docker-compose.yml → http://whisper:8080
WHISPER_URL=http://localhost:8080

# Triton gRPC (GDINO object detection)
# Bare metal: localhost:8001
# Docker:     overridden in docker-compose.yml → triton:8001
TRITON_URL=localhost:8001

# Storage
# Bare metal: ./family.md
# Docker:     overridden in docker-compose.yml → /data/family.md
FAMILY_MD_PATH=./family.md

# Phone to name mapping (JSON string)
# Key = full E.164 phone number, value = display name
PHONE_TO_NAME={"+447911123456": "Alice", "+447911987654": "Bob"}
