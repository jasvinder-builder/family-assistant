.ultralytics/
*.pt

# ONNX model files — exported at runtime, large binaries
*.onnx

# TRT engine files — large binary, exported at runtime
models/*.engine
models/*.meta.json

# Test videos — local only
*.mp4
*.mov
*.avi

# Logs
logs/

# Editor
.vscode/
.idea/
*.swp
