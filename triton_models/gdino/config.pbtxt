name: "gdino"
backend: "python"
max_batch_size: 0

# Uses the HTTP transport (not gRPC) from the app side.  Triton 24.04's gRPC
# shared-memory path broadcasts the first tensor element to every position for
# all dtypes; HTTP uses a different C++ data path that is unaffected.

input [
  {
    name: "IMAGE"
    data_type: TYPE_UINT8
    dims: [ -1 ]
  },
  {
    name: "QUERIES"
    data_type: TYPE_UINT8
    dims: [ -1 ]
  },
  {
    name: "THRESHOLD"
    data_type: TYPE_FP32
    dims: [ 1 ]
  },
  {
    name: "TEXT_THRESHOLD"
    data_type: TYPE_FP32
    dims: [ 1 ]
  }
]

output [
  {
    name: "BOXES"
    data_type: TYPE_FP32
    dims: [ -1, 4 ]
  },
  {
    name: "SCORES"
    data_type: TYPE_FP32
    dims: [ -1 ]
  },
  {
    name: "LABELS"
    data_type: TYPE_FP32
    dims: [ -1 ]
  }
]

instance_group [{ kind: KIND_GPU, count: 1 }]
